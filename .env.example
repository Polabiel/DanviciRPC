DISCORD_CLIENT_ID=
# Example environment file for DaVinciRPC
# Replace values as needed for your environment.
LARGE_IMAGE_KEY=resolve
# Optional path overrides for Resolve scripting modules (leave empty to use defaults)
RESOLVE_SCRIPT_PATH=
DAVINCI_RESOLVE_SCRIPT_PATH=
# Feature flags and debug options
ENABLE_RESOLVE_API=false
DEBUG_RPC=false
# When true, force the app to run even if a conflicting instance is detected
FORCE_RUN=false
# Interval between presence updates (seconds)
UPDATE_INTERVAL=15